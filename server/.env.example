# ==============================
# Server Environment Variables
# ==============================
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Mac/Linux/Git Bash)
#   copy .env.example .env (Windows CMD)

# ── App ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/linkmint
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/linkmint
MONGO_URI=mongodb://127.0.0.1:27017/linkmint

# ── Auth Secrets ──────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run the command twice — once for each secret below
SESSION_SECRET=replace_with_random_64_char_string
ACCESS_TOKEN_SECRET=replace_with_different_random_64_char_string

# ── URLs ──────────────────────────────────────────
CLIENT_URL=http://localhost:5173
BASE_URL=http://localhost:5000

# ── Email — Brevo (active) ────────────────────────
# Sign up at https://www.brevo.com
# API key:       https://app.brevo.com/settings/keys/api
# Verify sender: Brevo dashboard → Senders & Domains
EMAIL_FROM=you@yourdomain.com
BrevoApiKey=your_brevo_api_key_here

# ── Email — SMTP (legacy / unused by default) ─────
# These were used with nodemailer. Not active in current code.
# Fill in only if you switch back to SMTP sending.
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_gmail_app_password


# ── Resend (legacy / unused by default) ───────────
# Was used during early development. Not active in current code.
RESEND_API_KEY=your_resend_api_key_here

# ── Google OAuth 2.0 ──────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local): http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GitHub OAuth ──────────────────────────────────
# Create at: https://github.com/settings/developers
# Authorization callback URL (local): http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
